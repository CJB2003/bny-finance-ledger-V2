<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<AnchorPane prefHeight="750" prefWidth="850" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.LedgerController">
    <HBox alignment="CENTER_LEFT" prefHeight="50" style="-fx-background-color: #f4f4f4; -fx-padding: 14 20 14 20; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0">
        <Label style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a2b4a;" text="BNY Ledger" />
        <Region HBox.hgrow="ALWAYS" />
        <Label fx:id="accountLabel" style="-fx-font-size: 13px; -fx-text-fill: #888;" text="Account #4821" />
    </HBox>

    <HBox alignment="CENTER_LEFT" prefHeight="50" style="-fx-background-color: #1a2b4a;" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="50">
        <Button fx:id="allButton" onAction="#onAll" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 15 35 15 35; -fx-cursor: hand; -fx-border-color: transparent transparent white transparent; -fx-border-width: 0 0 3 0;" text="All" />
        <Button fx:id="depositsButton" onAction="#onDeposits" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 13px; -fx-padding: 15 35 15 35; -fx-cursor: hand; -fx-border-color: transparent; -fx-border-width: 0 0 3 0;" text="Deposits" />
        <Button fx:id="paymentsButton" onAction="#onPayments" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 13px; -fx-padding: 15 35 15 35; -fx-cursor: hand; -fx-border-color: transparent; -fx-border-width: 0 0 3 0;" text="Payments" />
        <Button fx:id="reportsButton" onAction="#onReports" style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 13px; -fx-padding: 15 35 15 35; -fx-cursor: hand; -fx-border-color: transparent; -fx-border-width: 0 0 3 0;" text="Reports" />
        <Region HBox.hgrow="ALWAYS" />
    </HBox>

    <TableView fx:id="transactionTable" prefHeight="650.0" prefWidth="850.0" style="-fx-background-color: white; -fx-border-color: transparent;" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="100">
        <columns>
            <TableColumn fx:id="dateColumn" prefWidth="140.0" text="Date" />
            <TableColumn fx:id="timeColumn" prefWidth="120.0" text="Time" />
            <TableColumn fx:id="descColumn" prefWidth="270.0" text="Description" />
            <TableColumn fx:id="vendorColumn" prefWidth="160.0" text="Vendor" />
            <TableColumn fx:id="amountColumn" prefWidth="158.0" text="Amount" />
        </columns>
        <placeholder>
            <Label style="-fx-text-fill: #888; -fx-font-size: 14px;" text="No transactions found." />
        </placeholder>
    </TableView>
</AnchorPane>
