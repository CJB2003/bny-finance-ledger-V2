<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<AnchorPane xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml" prefWidth="850" prefHeight="750" fx:controller="controllers.LedgerController">
    <HBox AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" prefHeight="50" style="-fx-background-color: #f4f4f4; -fx-padding: 14 20 14 20; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0;" alignment="CENTER_LEFT">
        <Label text="BNY Ledger" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #1a2b4a;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="accountLabel" text="Account #4821" style="-fx-font-size: 13px; -fx-text-fill: #888;"/>
    </HBox>

    <HBox AnchorPane.topAnchor="50" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" prefHeight="50" style="-fx-background-color: #1a2b4a;" alignment="CENTER_LEFT">
        <Button fx:id="allButton" text="All"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 13px; -fx-padding: 15 35 15 35; -fx-cursor: hand; -fx-border-color: transparent transparent white transparent; -fx-border-width: 0 0 3 0;"
                onAction="#onAll"/>
        <Button fx:id="depositsButton" text="Deposits"
                style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 13px; -fx-padding: 15 35 15 35; -fx-cursor: hand; -fx-border-color: transparent; -fx-border-width: 0 0 3 0;"
                onAction="#onDeposits"/>
        <Button fx:id="paymentsButton" text="Payments"
                style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 13px; -fx-padding: 15 35 15 35; -fx-cursor: hand; -fx-border-color: transparent; -fx-border-width: 0 0 3 0;"
                onAction="#onPayments"/>
        <Button fx:id="reportsButton" text="Reports"
                style="-fx-background-color: transparent; -fx-text-fill: rgba(255,255,255,0.6); -fx-font-size: 13px; -fx-padding: 15 35 15 35; -fx-cursor: hand; -fx-border-color: transparent; -fx-border-width: 0 0 3 0;"
                onAction="#onReports"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="homeButton" text="Home"
                style="-fx-background-color: rgba(255,255,255,0.1); -fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 13px; -fx-padding: 8 20 8 20; -fx-cursor: hand; -fx-border-color: rgba(255,255,255,0.2); -fx-border-radius: 5; -fx-background-radius: 5;"
                onAction="#onHome">
            <HBox.margin>
                <Insets right="20"/>
            </HBox.margin>
        </Button>
    </HBox>

    <TableView fx:id="transactionTable" AnchorPane.topAnchor="100" AnchorPane.bottomAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" style="-fx-background-color: white; -fx-border-color: transparent;">
        <columns>
            <TableColumn fx:id="dateColumn" text="Date" prefWidth="130"/>
            <TableColumn fx:id="timeColumn" text="Time" prefWidth="110"/>
            <TableColumn fx:id="descColumn" text="Description" prefWidth="220"/>
            <TableColumn fx:id="vendorColumn" text="Vendor" prefWidth="170"/>
            <TableColumn fx:id="amountColumn" text="Amount" prefWidth="120"/>
        </columns>
        <placeholder>
            <Label text="No transactions found."
                   style="-fx-text-fill: #888; -fx-font-size: 14px;"/>
        </placeholder>
    </TableView>
</AnchorPane>
